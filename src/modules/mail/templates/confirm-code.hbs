<html lang='uz'>

<head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Hisobni tasdiqlash</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 600px;
            margin: 20px auto;
            background: #ffffff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        h1 {
            color: #333;
        }

        p {
            font-size: 16px;
            color: #444;
        }

        .code {
            font-size: 28px;
            font-weight: bold;
            color: #2563eb;
            margin: 20px 0;
            letter-spacing: 4px;
        }

        .footer {
            margin-top: 20px;
            font-size: 12px;
            color: #888;
        }
    </style>
</head>

<body>
    <div class='container'>
        <h1>Food Express</h1>
        <p>Emailni tasdiqlash uchun kod:</p>
        <div class='code'>{{code}}</div>
        <p class='footer'>Ushbu kodni hech kimga bermang</p>
    </div>
</body>

</html>